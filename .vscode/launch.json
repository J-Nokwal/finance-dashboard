{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Node: Run File",
      "program": "${file}",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "sourceMaps": true,
      "envFile": "${workspaceFolder}/.env.dev"
    }
  ]
}