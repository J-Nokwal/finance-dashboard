// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id     String  @id @default(uuid())
  email  String  @unique
  name   String?
  avatar String?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  authAccounts        AuthAccount[]
  organizationMembers OrganizationMember[]
  projectMembers      ProjectMember[]      @relation("ProjectMemberUser")
  projectsAdded       ProjectMember[]      @relation("ProjectMemberAddedBy")
  sessions            AuthSession[]
  invites             Invitation[]
  financialRecords    FinancialRecord[]

  @@index([email])
}

model AuthAccount {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  provider   AuthProvider
  providerId String? // google sub OR email

  passwordHash String? // for EMAIL_PASSWORD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerId])
  @@index([userId])
}

model AuthSession {
  id String @id @default(uuid())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  refreshToken String @unique

  userAgent String?
  ipAddress String?

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model OtpCode {
  id        String     @id @default(uuid())
  email     String
  codeHash  String
  purpose   OtpPurpose
  expiresAt DateTime
  usedAt    DateTime? // null = not yet used
  createdAt DateTime   @default(now())

  @@index([email, purpose])
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  createdAt   DateTime @default(now())
  description String?

  members  OrganizationMember[]
  projects Project[]
  invites  Invitation[]

  deletedAt DateTime?
}

model OrganizationMember {
  id               String           @id @default(uuid())
  organizationRole OrganizationRole @default(MEMBER)
  userId           String
  organizationId   String
  createdAt        DateTime         @default(now())

  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])

  @@unique([userId, organizationId]) // prevent duplicate membership
}

model Project {
  id             String   @id @default(uuid())
  name           String
  organizationId String
  baseCurrency   Currency @default(USD)
  createdAt      DateTime @default(now())

  organization     Organization              @relation(fields: [organizationId], references: [id])
  members          ProjectMember[]
  invites          InvitationProject[]
  financialRecords FinancialRecord[]
  recordCategories FinancialRecordCategory[]
  recordTags       FinancialRecordTag[]

  deletedAt DateTime?
}

model ProjectMember {
  id          String      @id @default(uuid())
  projectId   String
  userId      String
  projectRole ProjectRole @default(MEMBER)
  addedById   String

  project     Project             @relation(fields: [projectId], references: [id])
  user        User                @relation("ProjectMemberUser", fields: [userId], references: [id])
  addedBy     User                @relation("ProjectMemberAddedBy", fields: [addedById], references: [id])
  permissions ProjectPermission[]

  @@unique([projectId, userId])
}

model ProjectPermission {
  id              String        @id @default(uuid())
  projectMemberId String
  domain          ProjectDomain // FINANCE, SUPPORT, ANALYST
  accessLevel     DomainAccess // READ, WRITE, MANAGE

  projectMember ProjectMember @relation(fields: [projectMemberId], references: [id], onDelete: Cascade)

  @@unique([projectMemberId, domain])
}

model Invitation {
  id String @id @default(uuid())

  email String

  organizationId String
  invitedById    String

  token String @unique

  status    InvitationStatus @default(PENDING)
  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  organization Organization @relation(fields: [organizationId], references: [id])
  invitedBy    User         @relation(fields: [invitedById], references: [id])

  orgRole OrganizationRole @default(MEMBER)

  projectInvites InvitationProject[]

  @@index([email])
}

model InvitationProject {
  id String @id @default(uuid())

  invitationId String
  projectId    String

  role ProjectRole @default(MEMBER)

  invitation    Invitation                @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  project       Project                   @relation(fields: [projectId], references: [id])
  domainInvites InvitationProjectDomain[]

  @@unique([invitationId, projectId])
}

model InvitationProjectDomain {
  id                  String        @id @default(uuid())
  invitationProjectId String
  domain              ProjectDomain
  accessLevel         DomainAccess

  invitationProject InvitationProject @relation(fields: [invitationProjectId], references: [id], onDelete: Cascade)

  @@unique([invitationProjectId, domain])
}

model FinancialRecord {
  id              String        @id @default(uuid())
  createdByUserId String
  projectId       String
  type            RecordType
  categoryId      String
  source          RecordSource?
  description     String?
  date            DateTime

  amount       Decimal  @db.Decimal(12, 2)
  currency     Currency @default(INR)
  baseAmount   Decimal  @db.Decimal(12, 2)
  baseCurrency Currency
  exchangeRate Decimal  @db.Decimal(12, 6)

  createdByuser User                     @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  project       Project                  @relation(fields: [projectId], references: [id])
  category      FinancialRecordCategory? @relation(fields: [categoryId], references: [id])
  tags          FinancialRecordTagMap[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([date, id])
  @@index([createdByUserId])
  @@index([projectId])
  @@index([date])
  @@index([type])
  @@index([categoryId])
  @@index([projectId, date, id])
}

model FinancialRecordCategory {
  id   String     @id @default(uuid())
  name String
  type RecordType

  // scoped to project
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())

  records FinancialRecord[]

  // prevent duplicates per project
  @@unique([name, projectId])
}

model FinancialRecordTag {
  id   String @id @default(uuid())
  name String

  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  createdAt DateTime @default(now())

  records FinancialRecordTagMap[]

  @@unique([name, projectId])
}

model FinancialRecordTagMap {
  recordId String
  tagId    String

  record FinancialRecord    @relation(fields: [recordId], references: [id], onDelete: Cascade)
  tag    FinancialRecordTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([recordId, tagId])
}

enum AuthProvider {
  GOOGLE
  EMAIL_PASSWORD
  EMAIL_OTP
}

enum OrganizationRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectRole {
  ADMIN
  MEMBER
}

enum ProjectDomain {
  FINANCE
  DASHBOARD
}

enum DomainAccess {
  READ
  WRITE
  MANAGE
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  REVOKED
}

enum OtpPurpose {
  LOGIN
  EMAIL_VERIFICATION
  PASSWORD_RESET
  DELETE_ORGANIZATION
  DELETE_PROJECT
}

enum RecordType {
  INCOME
  EXPENSE
}

enum RecordSource {
  CASH
  BANK
  UPI
  CARD
  WALLET
}

enum Currency {
  INR
  USD
  EUR
}
